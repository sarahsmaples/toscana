<!DOCTYPE html>
<html lang="en" style="scroll-behavior: smooth;">
  <head>
    <!-- Standard meta tags -->
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description if description else 'Toscana 49 in midtown New York City features classic Italian dishes and fresh homemade pastas that are made daily in our own kitchen.' }}">
    <meta name="keywords" content="toscana 49, toscana, classic italian, homemade italian, new york, NYC, midtown, midtown east">
    <link rel="canonical" href="{{ client.domain }}{{ page.url }}">

    <!-- Social Media Display -->
    <meta property="og:title" content="{{ title if title != 'Home' else 'Toscana 49 | Midtown East Italian | NYC' }}"/>
    <meta property="og:description" content="{{ description if description else 'Toscana 49 in midtown New York City features classic Italian dishes and fresh homemade pastas that are made daily in our own kitchen.' }}"/>
    <meta property="og:type" content="restaurant"/>
    <meta property="og:url" content="{{ client.domain }}{{ page.url }}"/>
    <meta property="og:image" content="{{ client.domain }}/assets/images/og-image.webp"/>
    <meta property="og:image:secure_url" content="{{ client.domain }}/assets/images/og-image.webp"/>
    <meta property="og:locale" content="en_US"/>
    <meta property="og:site_name" content="Toscana 49 — New York, NY"/>

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="{{ title if title != 'Home' else 'Toscana 49 | Midtown East Italian | NYC' }}"/>
    <meta name="twitter:description" content="{{ description if description else 'Toscana 49 in midtown New York City features classic Italian dishes and fresh homemade pastas that are made daily in our own kitchen.' }}"/>
    <meta name="twitter:image" content="{{ client.domain }}/assets/images/og-image.webp"/>

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/assets/favicons/apple-touch-icon.png' | url }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ '/assets/favicons/favicon-32x32.png' | url }}?v1">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ '/assets/favicons/favicon-16x16.png' | url }}">
    <link rel="manifest" href="{{ '/assets/favicons/site.webmanifest' | url }}">
    <meta name="msapplication-TileColor" content="#faf8f5">
    <meta name="theme-color" content="#faf8f5">

    <!-- Sitewide Stylesheets and Scripts -->
    <link rel="stylesheet" href="{{ '/assets/css/styles.css' | url }}">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400..900&family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=Luckiest+Guy&family=Nunito:ital,wght@0,200..1000;1,200..1000&family=Rammetto+One&family=Roboto:ital,wght@0,100..900;1,100..900&family=Slackey&family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&family=Staatliches&family=UnifrakturMaguntia&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    {% block head %}{% endblock %}

    <title>{% if title == "Home" %}Toscana 49 | Midtown East Italian | NYC{% else %}{{ title }} | Toscana 49 — NYC{% endif %}</title>

    <!-- Restaurant Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Restaurant",
        "name": "{{ client.name }}",
        "description": "Toscana 49 in midtown New York City features classic Italian dishes and fresh homemade pastas that are made daily in our own kitchen.",
        "url": "{{ client.domain }}",
        "telephone": "{{ client.phone }}",
        "email": "{{ client.email }}",
        "servesCuisine": ["Italian", "Pasta", "Mediterranean"],
        "priceRange": "{{ client.priceRange }}",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "{{ client.address.street }}",
          "addressLocality": "{{ client.address.city }}",
          "addressRegion": "{{ client.address.stateAbbr }}",
          "postalCode": "{{ client.address.zip }}",
          "addressCountry": "US"
        },
        "logo": "{{ client.domain }}/assets/images/logo.png",
        "image": "{{ client.domain }}/assets/images/og-image.webp",
        "hasMap": "https://maps.google.com/?q=Toscana+49+New+York+NY",
        "reservationUrl": "{{ client.reservationUrl }}",
        "areaServed": [
          { "@type": "City", "name": "New York" },
          { "@type": "Neighborhood", "name": "Midtown East" },
          { "@type": "Neighborhood", "name": "Midtown Manhattan" },
          { "@type": "Neighborhood", "name": "Murray Hill" },
          { "@type": "Neighborhood", "name": "Turtle Bay" }
        ]
      }
    </script>

    <!-- Google Analytics -->
    <script>
      (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
      (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
      m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
      })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');

      ga('create', 'UA-76973001-1', 'auto');
      ga('send', 'pageview');
    </script>

    <!-- Prevent scroll restoration flash -->
    <script>if (history.scrollRestoration) history.scrollRestoration = 'manual';</script>

  </head>

  <body class="overflow-x-hidden">
    {% include "components/header.njk" %}
    <main>
      {% block content %}{% endblock %}
    </main>
    {% include "components/footer.njk" %}
    <script src="{{ '/assets/js/main.js' | url }}"></script>
  </body>
</html>
