---
title: Home
description: "Musashi brings premium sushi and Japanese cuisine to Frisco, TX. Fresh fish flown in regularly, an upscale atmosphere, and an unforgettable dining experience just north of Dallas. Reserve your table today."
---

{% extends "layouts/base.njk" %}

{% block head %}
<script id="marketing-popup-script" data-restaurant-id="1154" src="https://88restaurants.com/uploads/popup.js"></script>

<script>
document.addEventListener("DOMContentLoaded", async () => {
  console.log("sup")
  try {
    const response = await fetch(
      "https://88restaurants.com/restaurants/1154/online_orders/discount_button"
    );
    const html = await response.text();
    document.body.insertAdjacentHTML("beforeend", html);
  } catch (error) {
    console.error("Error fetching button:", error);
  }
});
</script>

{% endblock %}

{% block content %}

  <!-- Hero -->
  <section id="hero" class="relative overflow-hidden min-h-screen" style="min-height: 100vh;">
    <!-- Intro video -->
    <video class="absolute inset-0 w-full h-full object-cover" autoplay muted loop playsinline poster="{{ '/assets/images/hero-mobile.jpg' | url }}">
      <source src="{{ '/assets/videos/hero.mp4' | url }}" type="video/mp4">
    </video>
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-dark-bg opacity-20"></div>
    <div class="relative max-w-screen-xl px-4 py-24 mx-auto lg:py-36 lg:grid lg:grid-cols-12 lg:gap-8 items-center">
      <div class="lg:col-span-7 text-center lg:text-left">
        <p class="font-cormorant uppercase tracking-widest text-base text-gray-400 mb-4">Frisco, Texas</p>
        <h1 class="text-5xl md:text-6xl xl:text-7xl text-white mb-6 leading-tight">
          Premium Sushi.<br>Elevated Experience.
        </h1>
        <p class="max-w-xl mx-auto lg:mx-0 mb-8 text-xl text-gray-400 font-light">
          Fresh fish flown in regularly. Traditional Japanese craftsmanship. An upscale dining destination in the heart of Frisco — setting a new standard north of Dallas.
        </p>
        <div class="hidden sm:flex flex-row gap-4 justify-center lg:justify-start">
          <a href="{{ '/' | url }}#reservations"
            class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-lg font-medium text-dark-bg bg-accent hover:bg-accent/90 focus:outline-none transition-colors duration-300">
            Reserve a Table
          </a>
          <a href="{{ '/menu' | url }}"
            class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-lg font-medium text-white border border-white hover:bg-accent hover:text-dark-bg hover:border-accent focus:outline-none transition-colors duration-300">
            View Our Menu
          </a>
        </div>
      </div>
    </div>
    <!-- Mobile CTAs: pinned near bottom of hero -->
    <div class="absolute bottom-10 inset-x-0 flex sm:hidden flex-col gap-4 px-4 items-center">
      <a href="{{ '/' | url }}#reservations"
        class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-lg font-medium text-dark-bg bg-accent hover:bg-accent/90 focus:outline-none transition-colors duration-300 w-full max-w-xs">
        Reserve a Table
      </a>
      <a href="{{ '/menu' | url }}"
        class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-lg font-medium text-white border border-white hover:bg-accent hover:text-dark-bg hover:border-accent focus:outline-none transition-colors duration-300 w-full max-w-xs">
        View Our Menu
      </a>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="bg-white">
    <div class="mx-auto max-w-screen-xl md:grid md:grid-cols-2 gap-0">

      <!-- Image collage (left) -->
      <div data-animate="fade-left" class="grid grid-cols-[335px_1fr] gap-2 p-2 h-[500px] md:h-auto md:min-h-[600px]">

        <!-- Column 1: sushi-3 full height (max 335px wide) -->
        <div class="overflow-hidden">
          <img src="{{ '/assets/images/sushi-3.jpg' | url }}" alt="Premium sushi at Musashi" class="w-full h-full object-cover">
        </div>

        <!-- Column 2: uni + spider-bun + sushi-2 stacked -->
        <div class="grid grid-rows-3 gap-2">
          <div class="overflow-hidden">
            <img src="{{ '/assets/images/uni-2.jpg' | url }}" alt="Fresh uni at Musashi" class="w-full h-full object-cover">
          </div>
          <div class="overflow-hidden">
            <img src="{{ '/assets/images/spider-bun.jpg' | url }}" alt="Spider buns at Musashi" class="w-full h-full object-cover">
          </div>
          <div class="overflow-hidden">
            <img src="{{ '/assets/images/sushi-2.jpg' | url }}" alt="Sushi at Musashi" class="w-full h-full object-cover">
          </div>
        </div>
      </div>

      <!-- Text (right) -->
      <div class="relative flex flex-col justify-center px-8 py-16 lg:px-14">
        <img src="{{ '/assets/images/musashi.png' | url }}" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-contain object-center opacity-20 z-0 pointer-events-none select-none">
        <div data-animate="fade-up" class="relative z-10">
          <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-4">About Us</p>
          <h2 class="text-5xl md:text-6xl text-gray-900 mb-8">Welcome to Musashi</h2>
          <p class="text-gray-700 font-light text-xl leading-relaxed mb-6">
            Based out of Frisco, Texas, Musashi is an upscale casual Japanese restaurant specializing in sushi, izakaya, and tapas-style dining. We offer items ranging from small plates provided over several courses, to interactive tabletop tastings. Our dishes can be paired with a diverse selection of Japanese sake and whisky to elevate the overall experience.
          </p>
          <p class="text-gray-700 font-light text-xl leading-relaxed">
            Our goal is to present the community a reliable option to enjoy quality cuisines and service, while being able to relax in a more elegant yet inviting atmosphere. Here at Musashi, we apply a strong emphasis on education, first principles, along with uncompromising standards for craftsmanship, ensuring each visit is meaningful and memorable.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Hours -->
  <section class="relative overflow-hidden border-t border-gray-800" style="background-image: url('{{ '/assets/images/hours-bg.jpg' | url }}'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-dark-bg opacity-70"></div>
    <div class="relative max-w-screen-xl px-4 py-16 mx-auto md:py-24">
      <div class="grid md:grid-cols-3 gap-10 mx-auto" style="max-width: 68rem;">

        <!-- Lunch -->
        <div data-animate="fade-up" class="text-center">
          <h2 class="font-cormorant uppercase tracking-widest text-4xl text-accent mb-4">Lunch Hours</h2>
          <div class="text-base text-gray-300 font-light space-y-1">
            <p class="text-white font-normal">Mon – Thur</p>
            <p>11:00 am – 2:30 pm</p>
          </div>
        </div>

        <!-- Dinner -->
        <div data-animate="fade-up" style="--animate-delay: 150ms" class="text-center">
          <h2 class="font-cormorant uppercase tracking-widest text-4xl text-accent mb-4">Dinner Hours</h2>
          <div class="text-base text-gray-300 font-light space-y-3">
            <div>
              <p class="text-white font-normal">Mon – Thur</p>
              <p>4:00 pm – 10:00 pm</p>
            </div>
            <div>
              <p class="text-white font-normal">Fri – Sat</p>
              <p>11:00 am – 11:00 pm</p>
            </div>
            <div>
              <p class="text-white font-normal">Sun</p>
              <p>11:00 am – 10:00 pm</p>
            </div>
          </div>
        </div>

        <!-- Happy Hour -->
        <div data-animate="fade-up" style="--animate-delay: 300ms" class="text-center">
          <h2 class="font-cormorant uppercase tracking-widest text-4xl text-accent mb-4">Happy Hour</h2>
          <div class="text-base text-gray-300 font-light space-y-1">
            <p class="text-white font-normal">Mon – Fri</p>
            <p>4:00 pm – 6:00 pm</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Menus -->
  <section class="bg-stone-50 border-t border-stone-200">
    <div class="max-w-screen-xl mx-auto px-4 py-16 md:py-24">
      <div class="text-center mb-12">
        <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-3">Explore</p>
        <h2 class="text-5xl md:text-6xl text-gray-900">Our Menus</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-stone-200">
        <a href="{{ '/menu/sushi-bar/' | url }}" class="group bg-stone-50 hover:bg-accent/10 transition-colors duration-300 flex flex-col items-center text-center px-8 py-12">
          <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-4">Experience</p>
          <h3 class="text-5xl text-gray-900 mb-4">Sushi Bar</h3>
          <p class="text-gray-500 font-light text-lg leading-relaxed mb-6">Omakase-style selections crafted at the bar. Chef's choice of the freshest cuts, daily.</p>
          <span class="font-cormorant uppercase tracking-widest text-base text-accent group-hover:text-dark-bg transition-colors duration-300">View Menu →</span>
        </a>
        <a href="{{ '/menu/day/' | url }}" class="group bg-stone-50 hover:bg-accent/10 transition-colors duration-300 flex flex-col items-center text-center px-8 py-12">
          <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-4">Afternoon</p>
          <h3 class="text-5xl text-gray-900 mb-4">Day Menu</h3>
          <p class="text-gray-500 font-light text-lg leading-relaxed mb-6">Lighter bites and lunch offerings — sushi, small plates, and Japanese tapas.</p>
          <span class="font-cormorant uppercase tracking-widest text-base text-accent group-hover:text-dark-bg transition-colors duration-300">View Menu →</span>
        </a>
        <a href="{{ '/menu/night/' | url }}" class="group bg-stone-50 hover:bg-accent/10 transition-colors duration-300 flex flex-col items-center text-center px-8 py-12">
          <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-4">Evening</p>
          <h3 class="text-5xl text-gray-900 mb-4">Night Menu</h3>
          <p class="text-gray-500 font-light text-lg leading-relaxed mb-6">An elevated dinner experience with premium rolls, izakaya, and multi-course options.</p>
          <span class="font-cormorant uppercase tracking-widest text-base text-accent group-hover:text-dark-bg transition-colors duration-300">View Menu →</span>
        </a>
        <a href="{{ '/menu/drinks/' | url }}" class="group bg-stone-50 hover:bg-accent/10 transition-colors duration-300 flex flex-col items-center text-center px-8 py-12">
          <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-4">Beverages</p>
          <h3 class="text-5xl text-gray-900 mb-4">Drink Menu</h3>
          <p class="text-gray-500 font-light text-lg leading-relaxed mb-6">Japanese sake, whisky, craft cocktails, and a curated wine list to complement every dish.</p>
          <span class="font-cormorant uppercase tracking-widest text-base text-accent group-hover:text-dark-bg transition-colors duration-300">View Menu →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Reservations -->
  <section id="reservations" class="bg-dark-bg border-t border-gray-800">
    <div class="flex min-h-[600px]">

      <!-- Left: text + widget (50%) -->
      <div data-animate="fade-up" class="flex flex-col items-center justify-center text-center px-8 py-16 lg:px-14 w-full md:w-1/2 shrink-0">
        <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-3">Book Your Experience</p>
        <h2 class="text-5xl md:text-6xl text-white mb-4">Reserve a Table</h2>
        <p class="text-gray-400 font-light text-lg mb-8">Join us for dinner at Musashi — Frisco's destination for premium sushi and Japanese cuisine. Reservations recommended.</p>
        <iframe id="widget" width="300" height="442" src="https://88restaurants.com/1154/widgets/5155" style="border: none; background: none; border-radius: 5px;"></iframe>
      </div>

      <!-- Right: image (50%) -->
      <div data-animate="fade-right" class="hidden md:block flex-1 relative">
        <img src="{{ '/assets/images/okonomiyaki-cropped.png' | url }}" alt="Okonomiyaki at Musashi" class="absolute inset-0 w-full h-full object-cover object-left">
      </div>

    </div>
  </section>

  <!-- Private Events -->
  <section class="bg-stone-50 border-t border-stone-200">
    <div class="mx-auto max-w-screen-xl md:grid md:grid-cols-2 gap-0">

      <!-- Left: image -->
      <div data-animate="fade-left" class="flex items-center justify-center px-8 py-12">
        <img src="{{ '/assets/images/lantern.png' | url }}" alt="Lanterns at Musashi" class="max-h-72 w-auto object-contain">
      </div>

      <!-- Right: text -->
      <div data-animate="fade-up" class="flex flex-col justify-center px-8 py-16 lg:px-14">
        <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-4">Celebrate With Us</p>
        <h2 class="text-5xl md:text-6xl text-gray-900 mb-6">Private Events</h2>
        <p class="text-gray-600 font-light text-xl leading-relaxed mb-8">
          Planning a birthday, corporate dinner, or special celebration? Musashi offers an elevated setting for private and group events. Let us craft an unforgettable experience tailored to your occasion.
        </p>
        <a href="{{ '/parties/' | url }}"
          class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-lg font-medium text-dark-bg bg-accent hover:bg-accent/90 focus:outline-none transition-colors duration-300 self-start">
          Inquire About Events
        </a>
      </div>

    </div>
  </section>

  <!-- Gallery Strip -->
  <section class="gallery-strip-section relative overflow-hidden bg-dark-bg" style="height: 220px;">
    <div class="gallery-strip-track" id="galleryStripTrack">
      {% set stripImages = [
        "g23.jpeg","g7.jpg","g12.jpg","g27.jpg","g36.jpg",
        "g21.jpeg","g38.jpg","g44.jpg","g16.jpg","g6.jpg",
        "g31.jpg","g18.JPG","g47.jpg","g24.jpeg","g45.jpg",
        "g22.jpeg","g35.jpg","g13.jpg","g3.jpeg","g26.jpg",
        "g5.jpg","g37.jpg","g10.jpg","g34.jpg","g1.jpg"
      ] %}
      {% for img in stripImages %}
        <img src="{{ ('/assets/images/gallery/' + img) | url }}" alt="" loading="lazy">
      {% endfor %}
      {# Duplicate for seamless loop #}
      {% for img in stripImages %}
        <img src="{{ ('/assets/images/gallery/' + img) | url }}" alt="" loading="lazy" aria-hidden="true">
      {% endfor %}
    </div>
    <!-- Hover overlay -->
    <div class="gallery-strip-overlay">
      <a href="{{ '/gallery' | url }}" class="font-cormorant uppercase tracking-widest text-lg text-white border border-white px-8 py-3 hover:bg-accent hover:text-dark-bg hover:border-accent transition-colors duration-300">
        View Gallery
      </a>
    </div>
    <style>
      .gallery-strip-track {
        display: flex;
        gap: 6px;
        height: 100%;
        width: max-content;
        animation: gallery-scroll 120s linear infinite;
      }
      .gallery-strip-track img {
        height: 100%;
        width: auto;
        object-fit: cover;
        display: block;
        flex-shrink: 0;
      }
      @keyframes gallery-scroll {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }
      .gallery-strip-section:hover .gallery-strip-track {
        animation-play-state: paused;
      }
      .gallery-strip-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: background 0.3s ease, opacity 0.3s ease;
        pointer-events: none;
      }
      .gallery-strip-section:hover .gallery-strip-overlay {
        background: rgba(0,0,0,0.55);
        opacity: 1;
        pointer-events: auto;
      }
    </style>
  </section>

  <!-- Contact -->
  <section id="contact" class="bg-dark-bg border-t border-gray-800">
    <div class="flex min-h-[600px]">

      <!-- Left: image -->
      <div data-animate="fade-left" class="hidden md:block w-1/2 shrink-0 relative">
        <img src="{{ '/assets/images/sushi-1.jpg' | url }}" alt="Premium sushi at Musashi" class="absolute inset-0 w-full h-full object-cover">
      </div>

      <!-- Right: heading + info + form -->
      <div data-animate="fade-up" class="flex flex-col justify-center px-8 py-16 lg:px-14 w-full md:w-1/2">
        <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-3">Get In Touch</p>
        <h2 class="text-5xl md:text-6xl text-white mb-8">Contact Us</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
          <!-- Address -->
          <div>
            <h4 class="font-cormorant uppercase tracking-widest text-2xl text-accent mb-3">Address</h4>
            <div class="text-base text-gray-400 font-light space-y-1">
              <p>4606 Frisco Green Ave</p>
              <p>Suite 103</p>
              <p>Frisco, TX 75034</p>
              <a href="https://maps.google.com/?q=4606+Frisco+Green+Ave+Suite+103+Frisco+TX+75034" target="_blank" rel="noopener noreferrer" class="inline-block mt-3 text-sm font-cormorant uppercase tracking-widest text-accent hover:text-white transition-colors duration-300">Get Directions →</a>
            </div>
          </div>
          <!-- Contact -->
          <div>
            <h4 class="font-cormorant uppercase tracking-widest text-2xl text-accent mb-3">Phone</h4>
            <div class="text-base text-gray-400 font-light space-y-2">
              <p><a href="tel:+12144077590" class="hover:text-white transition-colors duration-300">(214) 407-7590</a></p>
            </div>
          </div>
          <!-- Socials -->
          <div>
            <h4 class="font-cormorant uppercase tracking-widest text-2xl text-accent mb-3">Follow Us</h4>
            <div class="text-base text-gray-400 font-light space-y-2">
              <p><a href="https://www.facebook.com/musashidallas" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-300"><i class="bi bi-facebook"></i> Facebook</a></p>
              <p><a href="https://www.instagram.com/musashidallas/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors duration-300"><i class="bi bi-instagram"></i> Instagram</a></p>
            </div>
          </div>
        </div>

        <iframe src="https://88restaurants.com/1154/contact_forms" frameborder="0" width="100%" height="545" scrolling="no" style="border-radius: 10px;"></iframe>
      </div>

    </div>
  </section>

{% endblock %}
