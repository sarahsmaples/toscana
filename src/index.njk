---
title: Home
description: "Toscana 49 in midtown New York City features classic Italian dishes and fresh homemade pastas that are made daily in our own kitchen."
---

{% extends "layouts/base.njk" %}

{% block content %}

  <!-- Hero -->
  <section id="hero" class="relative overflow-hidden min-h-screen" style="min-height: 100vh;">
    <!-- Slideshow -->
    <div id="hero-slides" class="absolute inset-0">
      <div class="hero-slide absolute inset-0 transition-opacity duration-1000" style="background-image: url('{{ '/assets/images/hero-1.jpg' | url }}'); background-size: cover; background-position: center;"></div>
      <div class="hero-slide absolute inset-0 transition-opacity duration-1000 opacity-0" style="background-image: url('{{ '/assets/images/hero-2.JPG' | url }}'); background-size: cover; background-position: center;"></div>
      <div class="hero-slide absolute inset-0 transition-opacity duration-1000 opacity-0" style="background-image: url('{{ '/assets/images/hero-3.jpg' | url }}'); background-size: cover; background-position: center;"></div>
      <div class="hero-slide absolute inset-0 transition-opacity duration-1000 opacity-0" style="background-image: url('{{ '/assets/images/hero-4.jpg' | url }}'); background-size: cover; background-position: center;"></div>
      <div class="hero-slide absolute inset-0 transition-opacity duration-1000 opacity-0" style="background-image: url('{{ '/assets/images/hero-5.jpeg' | url }}'); background-size: cover; background-position: center;"></div>
    </div>
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-dark-bg opacity-50"></div>
    <div class="relative max-w-screen-xl px-4 py-24 mx-auto lg:py-36 lg:grid lg:grid-cols-12 lg:gap-8 items-center">
      <div class="lg:col-span-7 text-center lg:text-left">
        <p class="font-cormorant uppercase tracking-widest text-base text-gray-200 mb-4">Midtown East, New York</p>
        <h1 class="text-5xl md:text-6xl xl:text-7xl text-white mb-6 leading-tight">
          Classic Italian.<br>Elevated Experience.
        </h1>
        <p class="max-w-xl mx-auto lg:mx-0 mb-8 text-xl text-gray-200 font-light">
          Homemade pastas made daily. Classic Italian dishes. An upscale dining destination in the heart of Midtown East — setting a new standard in New York City.
        </p>
        <div class="hidden sm:flex flex-row gap-4 justify-center lg:justify-start">
          <a href="#reservations"
            class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-lg font-medium text-dark-bg bg-accent hover:bg-accent/90 focus:outline-none transition-colors duration-300">
            Reserve a Table
          </a>
          <a href="{{ '/menu' | url }}"
            class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-lg font-medium text-white border border-white hover:bg-accent hover:text-dark-bg hover:border-accent focus:outline-none transition-colors duration-300">
            View Our Menu
          </a>
        </div>
      </div>
    </div>
    <!-- Mobile CTAs: pinned near bottom of hero -->
    <div class="absolute bottom-10 inset-x-0 flex sm:hidden flex-col gap-4 px-4 items-center">
      <a href="#reservations"
        class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-lg font-medium text-dark-bg bg-accent hover:bg-accent/90 focus:outline-none transition-colors duration-300 w-full max-w-xs">
        Reserve a Table
      </a>
      <a href="{{ '/menu' | url }}"
        class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-lg font-medium text-white border border-white hover:bg-accent hover:text-dark-bg hover:border-accent focus:outline-none transition-colors duration-300 w-full max-w-xs">
        View Our Menu
      </a>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="bg-warm-bg py-12 md:py-16">
    <div class="mx-auto max-w-screen-xl flex flex-col md:grid md:grid-cols-2 gap-0 md:items-center">

      <!-- Image (left on desktop, below text on mobile) -->
      <div data-animate="fade-left" class="relative overflow-hidden order-last md:order-first" style="height: 420px;">
        <img src="{{ '/assets/images/green-pasta.jpg' | url }}" alt="Inside Toscana 49" class="absolute inset-0 w-full h-full object-cover object-center">
      </div>

      <!-- Text (right) -->
      <div class="relative flex flex-col justify-center px-8 py-16 lg:px-14">
        <div data-animate="fade-up" class="relative z-10">
          <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-4">About Us</p>
          <h2 class="text-5xl md:text-6xl text-gray-900 mb-8">Benvenuti!</h2>
          <p class="text-gray-700 font-light text-xl leading-relaxed mb-6">
            Nestled in the heart of midtown Manhattan's east side, a stone's throw from New York City's finest hotels and Grand Central Station, Toscana49 offers a serene and elegant retreat from the bustle of the city.
          </p>
          <p class="text-gray-700 font-light text-xl leading-relaxed mb-6">
            We offer classic Italian dishes, and fresh homemade pastas that are made daily in our own kitchen, using time-honored traditional methods.
          </p>
          <p class="text-gray-700 font-light text-xl leading-relaxed">
            Our welcoming staff is ready to assist you in choosing wines from our extensive wine list, introducing you to our specials, which change daily to include the freshest ingredients available from local markets, or mixing you the perfect cocktail.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Strip -->
  <section class="gallery-strip-section relative overflow-hidden bg-dark-bg" style="height: 220px;">
    <div class="gallery-strip-track" id="galleryStripTrack">
      {% set stripImages = [
        "full_1.jpg","full_2.jpg","full_3.jpg","full_4.jpg","full_5.jpg",
        "full_6.jpg","full_7.jpg","full_8.jpg","full_9.jpg","full_10.jpg",
        "full_11.jpg","full_12.jpg","full_13.jpg","full_14.jpg","full_15.jpg"
      ] %}
      {% for img in stripImages %}
        <img src="{{ ('/assets/images/gallery/' + img) | url }}" alt="" loading="lazy">
      {% endfor %}
      {# Duplicate for seamless loop #}
      {% for img in stripImages %}
        <img src="{{ ('/assets/images/gallery/' + img) | url }}" alt="" loading="lazy" aria-hidden="true">
      {% endfor %}
    </div>
    <!-- Hover overlay -->
    <div class="gallery-strip-overlay">
      <a href="{{ '/gallery' | url }}" class="font-cormorant uppercase tracking-widest text-lg text-white border border-white px-8 py-3 hover:bg-accent hover:text-dark-bg hover:border-accent transition-colors duration-300">
        View Gallery
      </a>
    </div>
    <style>
      .gallery-strip-track {
        display: flex;
        gap: 6px;
        height: 100%;
        width: max-content;
        animation: gallery-scroll 120s linear infinite;
      }
      .gallery-strip-track img {
        height: 100%;
        width: auto;
        object-fit: cover;
        display: block;
        flex-shrink: 0;
      }
      @keyframes gallery-scroll {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }
      .gallery-strip-section:hover .gallery-strip-track {
        animation-play-state: paused;
      }
      .gallery-strip-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: background 0.3s ease, opacity 0.3s ease;
        pointer-events: none;
      }
      .gallery-strip-section:hover .gallery-strip-overlay {
        background: rgba(0,0,0,0.55);
        opacity: 1;
        pointer-events: auto;
      }
    </style>
  </section>

  <!-- Menus -->
  <section class="bg-warm-bg">
    <div class="max-w-screen-xl mx-auto px-4 py-16 md:py-24">
      <div class="text-center mb-12">
        <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-3">Explore</p>
        <h2 class="text-5xl md:text-6xl text-gray-900">Our Menus</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-stone-200">
        <a href="{{ '/menu/brunch/' | url }}" class="group bg-warm-bg hover:bg-accent/10 transition-colors duration-300 flex flex-col items-center text-center px-8 py-12">
          <p class="font-cormorant uppercase tracking-widest text-sm text-accent mb-4">Weekend</p>
          <h3 class="text-4xl text-gray-900 mb-4">Brunch</h3>
          <p class="text-gray-500 font-light text-lg leading-relaxed mb-6">A relaxed weekend experience with brunch favorites and daytime drinks.</p>
          <span class="font-cormorant uppercase tracking-widest text-base font-medium text-dark-bg bg-accent group-hover:bg-accent/90 px-6 py-2 transition-colors duration-300">View Menu →</span>
        </a>
        <a href="{{ '/menu/lunch/' | url }}" class="group bg-warm-bg hover:bg-accent/10 transition-colors duration-300 flex flex-col items-center text-center px-8 py-12">
          <p class="font-cormorant uppercase tracking-widest text-sm text-accent mb-4">Afternoon</p>
          <h3 class="text-4xl text-gray-900 mb-4">Lunch</h3>
          <p class="text-gray-500 font-light text-lg leading-relaxed mb-6">Lighter bites and midday offerings — fresh plates and seasonal selections.</p>
          <span class="font-cormorant uppercase tracking-widest text-base font-medium text-dark-bg bg-accent group-hover:bg-accent/90 px-6 py-2 transition-colors duration-300">View Menu →</span>
        </a>
        <a href="{{ '/menu/dinner/' | url }}" class="group bg-warm-bg hover:bg-accent/10 transition-colors duration-300 flex flex-col items-center text-center px-8 py-12">
          <p class="font-cormorant uppercase tracking-widest text-sm text-accent mb-4">Evening</p>
          <h3 class="text-4xl text-gray-900 mb-4">Dinner</h3>
          <p class="text-gray-500 font-light text-lg leading-relaxed mb-6">An elevated evening experience with premium dishes and multi-course options.</p>
          <span class="font-cormorant uppercase tracking-widest text-base font-medium text-dark-bg bg-accent group-hover:bg-accent/90 px-6 py-2 transition-colors duration-300">View Menu →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Reservations -->
  <section id="reservations" style="background-image: url('{{ '/assets/images/interior.jpg' | url }}'); background-size: cover; background-position: center;">
    <div style="background: rgba(250,248,245,0.88);">
    <div class="max-w-4xl mx-auto px-8 pt-16 lg:pt-24 lg:px-14">

      <!-- Two columns -->
      <div class="flex flex-col lg:flex-row lg:items-center gap-12 lg:gap-20 pb-16 lg:pb-24">

      <!-- Left: heading + text + CTA (CTA hidden on mobile) -->
      <div class="flex-1">
        <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-3">Reservations</p>
        <h2 class="text-4xl md:text-5xl text-gray-900 mb-6">Reserve a Table</h2>
        <p class="text-gray-600 font-light text-lg mb-4 leading-relaxed">
          Reservations are recommended. Walk-ins welcome based on availability. Use the widget to book a table for <strong class="font-normal text-gray-800">parties of 6 or fewer</strong>.
        </p>
        <div class="hidden lg:block">
          <p class="text-gray-500 font-light text-base mb-8 leading-relaxed">
            Hosting a larger group, private dinner, or special event? Our private upstairs space accommodates up to 50 guests with a dedicated bar.
          </p>
          <a href="{{ '/parties/' | url }}"
            class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-base font-medium text-dark-bg bg-accent hover:bg-accent/90 focus:outline-none transition-colors duration-300">
            Inquire About Private Events →
          </a>
        </div>
      </div>

      <!-- Right: widget -->
      <div class="flex justify-center shrink-0">
        <iframe id='widget' width='300' height='442' src='https://88restaurants.com/692/widgets/229' style='border: none; background: none; border-radius: 5px;'></iframe>
      </div>

      <!-- Private events CTA: mobile only, below widget -->
      <div class="lg:hidden">
        <p class="text-gray-500 font-light text-base mb-8 leading-relaxed">
          Hosting a larger group, private dinner, or special event? Our private upstairs space accommodates up to 50 guests with a dedicated bar.
        </p>
        <a href="{{ '/parties/' | url }}"
          class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-sm font-medium text-dark-bg bg-accent hover:bg-accent/90 focus:outline-none transition-colors duration-300 whitespace-nowrap">
          Private Events →
        </a>
      </div>

      </div>
    </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="bg-warm-bg">
    <div class="flex min-h-[600px]">

      <!-- Left: image -->
      <div data-animate="fade-left" class="hidden md:block w-1/2 shrink-0 relative">
        <img src="{{ '/assets/images/contact.jpg' | url }}" alt="Italian cuisine at Toscana 49" class="absolute inset-0 w-full h-full object-cover">
      </div>

      <!-- Right: heading + info + form -->
      <div data-animate="fade-up" class="flex flex-col justify-center px-8 py-16 lg:px-14 w-full md:w-1/2">
        <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-3">Get In Touch</p>
        <h2 class="text-5xl md:text-6xl text-gray-900 mb-8">Contact Us</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
          <!-- Address -->
          <div>
            <h4 class="font-cormorant uppercase tracking-widest text-2xl text-accent mb-3">Address</h4>
            <div class="text-base text-gray-600 font-light space-y-1">
              <p>{{ client.address.street }}</p>
              <p>{{ client.address.city }}, {{ client.address.stateAbbr }} {{ client.address.zip }}</p>
              <a href="https://maps.google.com/?q=Toscana+49+New+York+NY" target="_blank" rel="noopener noreferrer" class="inline-block mt-3 text-sm font-cormorant uppercase tracking-widest text-accent hover:text-gray-900 transition-colors duration-300">Get Directions →</a>
            </div>
          </div>
          <!-- Contact -->
          <div>
            <h4 class="font-cormorant uppercase tracking-widest text-2xl text-accent mb-3">Phone</h4>
            <div class="text-base text-gray-600 font-light space-y-2">
              <p><a href="tel:{{ client.phone }}" class="hover:text-gray-900 transition-colors duration-300">{{ client.phone }}</a></p>
            </div>
          </div>
          <!-- Socials -->
          <div>
            <h4 class="font-cormorant uppercase tracking-widest text-2xl text-accent mb-3">Follow Us</h4>
            <div class="text-base text-gray-600 font-light space-y-2">
              <p><a href="https://www.facebook.com/toscana49" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors duration-300"><i class="bi bi-facebook"></i> Facebook</a></p>
              <p><a href="https://www.instagram.com/toscana49/" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors duration-300"><i class="bi bi-instagram"></i> Instagram</a></p>
            </div>
          </div>
        </div>

        <iframe src="https://88restaurants.com/692/contact_forms" frameborder="0" width="100%" height="545" scrolling="no" ></iframe>
      </div>

    </div>
  </section>

{% endblock %}
